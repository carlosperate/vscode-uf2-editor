{
  "name": "uf2editor",
  "displayName": "UF2 Editor",
  "description": "View, inspect, and edit UF2 files.",
  "version": "0.1.1",
  "publisher": "carlosperate",
  "repository": {
    "type": "git",
    "url": "https://github.com/carlosperate/vscode-uf2-editor.git"
  },
  "bugs": {
    "url": "https://github.com/carlosperate/vscode-uf2-editor/issues"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "uf2",
    "hex",
    "binary",
    "microcontroller",
    "micro:bit"
  ],
  "qna": "https://github.com/carlosperate/vscode-uf2-editor/issues",
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "icon": "icon.png",
  "activationEvents": [],
  "main": "./dist-extension/extension.js",
  "browser": "./dist-extension/web/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  },
  "contributes": {
    "configuration": [
      {
        "title": "UF2 Editor",
        "properties": {
          "uf2editor.maxFileSize": {
            "type": "number",
            "minimum": 0,
            "default": 10,
            "description": "The max file size (in MB) that the editor will try to open before warning you."
          },
          "uf2editor.defaultEndianness": {
            "type": "string",
            "default": "little",
            "enum": [
              "little",
              "big"
            ],
            "description": "The endianness selected when loading the editor."
          },
          "uf2editor.columnWidth": {
            "type": "integer",
            "default": 16,
            "minimum": 1,
            "maximum": 512,
            "description": "The number of bytes per row to show in the editor."
          },
          "uf2editor.copyType": {
            "type": "string",
            "enum": [
              "Hex Octets",
              "Hex",
              "Literal",
              "UTF-8",
              "C",
              "Go",
              "Java",
              "JSON",
              "Base64"
            ],
            "default": "Hex Octets",
            "description": "Sets the default format in which bytes are copied"
          },
          "uf2editor.showDecodedText": {
            "type": "boolean",
            "default": true,
            "description": "Whether decoded text should be shown in the editor."
          },
          "uf2editor.showOpenFileButton": {
            "type": "boolean",
            "default": false,
            "description": "Show UF2 Editor button in editor menu."
          }
        }
      }
    ],
    "configurationDefaults": {},
    "customEditors": [
      {
        "viewType": "uf2Editor.view",
        "displayName": "UF2 Editor",
        "selector": [
          {
            "filenamePattern": "*.uf2"
          },
          {
            "filenamePattern": "*.UF2"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "uf2Editor.option",
        "displayName": "UF2 Editor",
        "selector": [
          {
            "filenamePattern": "*"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "uf2Editor.openFile",
        "category": "UF2 Editor",
        "title": "Open Active File in UF2 Editor",
        "icon": "$(file-binary)"
      },
      {
        "command": "uf2Editor.goToOffset",
        "category": "UF2 Editor",
        "title": "Go To Offset"
      },
      {
        "command": "uf2Editor.selectBetweenOffsets",
        "category": "UF2 Editor",
        "title": "Select Between Offsets"
      },
      {
        "command": "uf2Editor.copyAs",
        "category": "UF2 Editor",
        "title": "Copy As..."
      },
      {
        "command": "uf2Editor.switchEditMode",
        "category": "UF2 Editor",
        "title": "Switch Edit Mode"
      },
      {
        "command": "uf2Editor.copyOffsetAsHex",
        "category": "UF2 Editor",
        "title": "Copy Offset as Hex"
      },
      {
        "command": "uf2Editor.copyOffsetAsDec",
        "category": "UF2 Editor",
        "title": "Copy Offset as Decimal"
      },
      {
        "command": "uf2Editor.compareSelected",
        "category": "UF2 Editor",
        "title": "Compare Selected in UF2 Editor (Experimental)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "uf2Editor.goToOffset",
          "when": "uf2Editor:isActive"
        },
        {
          "command": "uf2Editor.switchEditMode",
          "when": "uf2Editor:isActive"
        },
        {
          "command": "uf2Editor.compareSelected",
          "when": "false"
        }
      ],
      "editor/title": [
        {
          "command": "uf2Editor.openFile",
          "group": "navigation@1",
          "when": "activeEditor && config.uf2editor.showOpenFileButton"
        }
      ],
      "webview/context": [
        {
          "command": "uf2Editor.copyOffsetAsDec",
          "group": "9_cutcopypaste",
          "when": "uf2Editor:isActive"
        },
        {
          "command": "uf2Editor.copyOffsetAsHex",
          "group": "9_cutcopypaste",
          "when": "uf2Editor:isActive"
        },
        {
          "when": "webviewId == 'uf2Editor.view'",
          "command": "uf2Editor.copyAs",
          "group": "9_cutcopypaste"
        },
        {
          "when": "webviewId == 'uf2Editor.option'",
          "command": "uf2Editor.copyAs",
          "group": "9_cutcopypaste"
        }
      ],
      "explorer/context": [
        {
          "command": "uf2Editor.compareSelected",
          "group": "3_compare@30",
          "when": "listDoubleSelection"
        }
      ]
    },
    "keybindings": [
      {
        "command": "uf2Editor.goToOffset",
        "key": "ctrl+g",
        "when": "activeCustomEditorId == uf2Editor.view"
      },
      {
        "command": "uf2Editor.goToOffset",
        "key": "ctrl+g",
        "when": "activeCustomEditorId == uf2Editor.option"
      },
      {
        "command": "uf2Editor.copyAs",
        "key": "alt+ctrl+c",
        "when": "activeCustomEditorId == uf2Editor.view"
      },
      {
        "command": "uf2Editor.copyAs",
        "key": "alt+ctrl+c",
        "when": "activeCustomEditorId == uf2Editor.option"
      },
      {
        "command": "uf2Editor.switchEditMode",
        "key": "Insert",
        "when": "uf2Editor:isActive"
      }
    ]
  },
  "scripts": {
    "compile": "tsc --noEmit && node .esbuild.config.js",
    "build:extension": "npm run compile",
    "build:standalone": "node standalone/esbuild.config.js --production",
    "build:all": "npm run build:extension && npm run build:standalone",
    "lint": "eslint src standalone --ext ts,tsx",
    "fmt": "prettier --write \"{src,media,shared,standalone}/**/*.{ts,tsx}\" && npm run lint -- --fix",
    "watch": "node .esbuild.config.js --watch",
    "watch:standalone": "node standalone/esbuild.config.js --watch",
    "test:extension": "node .esbuild.config.js && node ./src/test/runTest.js",
    "test:standalone": "node standalone/esbuild.test.config.js && node dist-standalone/test.js",
    "test": "npm run lint && npm run test:extension && npm run test:standalone"
  },
  "devDependencies": {
    "@testing-library/react": "^14.3.1",
    "@types/chai": "^4.3.0",
    "@types/diff": "^5.2.1",
    "@types/jsdom": "^27.0.0",
    "@types/mocha": "^9.0.0",
    "@types/node": "^18.11.9",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "@vscode/test-electron": "^2.3.9",
    "chai": "^4.3.4",
    "esbuild": "^0.19.0",
    "esbuild-css-modules-plugin": "^3.1.0",
    "eslint": "^8.56.0",
    "jsdom": "^27.2.0",
    "mocha": "^11.1.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.6",
    "@vscode/codicons": "0.0.27",
    "cockatiel": "^3.1.2",
    "diff": "^5.2.0",
    "js-base64": "^3.7.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-popper": "^2.3.0",
    "recoil": "^0.7.7",
    "tslib": "^2.6.2",
    "vscode-webview-tools": "^0.1.1"
  },
  "prettier": {
    "printWidth": 100,
    "tabWidth": 2,
    "arrowParens": "avoid"
  }
}
